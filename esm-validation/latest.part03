+/// Number of distinct sentences admitted by the synthetic grammar.
+const SENTENCE_SPACE: usize = ADJS.len() * NOUNS.len() * VERBS.len() * PREPS.len() * NOUNS.len();
+
+fn generate_unique_sentences(
+    rng: &mut StdRng,
+    count: usize,
+    seen: &mut HashSet<String>,
+) -> Vec<String> {
+    assert!(
+        seen.len() + count <= SENTENCE_SPACE,
+        "requested more unique sentences than the grammar can generate"
+    );
+    let mut sentences = Vec::with_capacity(count);
+    while sentences.len() < count {
+        let sentence = gen_sentence(rng);
+        if seen.insert(sentence.clone()) {
+            sentences.push(sentence);
+        }
     }
-    let mut chars: Vec<char> = text
-        .chars()
-        .collect::<std::collections::BTreeSet<_>>()
+    sentences
+}
+
+fn characters_in(texts: &[&str]) -> Vec<char> {
+    texts
+        .iter()
+        .flat_map(|text| text.chars())
+        .collect::<BTreeSet<_>>()
         .into_iter()
-        .collect();
-    chars.sort_unstable();
+        .collect()
+}
+
+/// Generates a corpus with no duplicate sentence strings.
+pub fn generate_corpus(rng: &mut StdRng, n_sentences: usize) -> (String, Vec<char>) {
+    let mut seen = HashSet::with_capacity(n_sentences);
+    let text = generate_unique_sentences(rng, n_sentences, &mut seen).concat();
+    let chars = characters_in(&[&text]);
     (text, chars)
 }
 
+/// Generates sentence-level unique training and holdout partitions.
+///
+/// A different RNG position is not sufficient to guarantee a held-out set:
+/// finite template grammars can emit the same literal sentence twice. This
+/// function enforces set disjointness and builds a vocabulary covering both
+/// partitions, so holdout evaluation cannot silently contain training strings
+/// or unknown characters.
+pub fn generate_disjoint_corpora(
+    rng: &mut StdRng,
+    train_sentences: usize,
+    holdout_sentences: usize,
+) -> (String, String, Vec<char>) {
+    assert!(
+        train_sentences + holdout_sentences <= SENTENCE_SPACE,
+        "requested split exceeds the finite synthetic grammar"
+    );
+    let mut seen = HashSet::with_capacity(train_sentences + holdout_sentences);
+    let train = generate_unique_sentences(rng, train_sentences, &mut seen).concat();
+    let holdout = generate_unique_sentences(rng, holdout_sentences, &mut seen).concat();
+    let chars = characters_in(&[&train, &holdout]);
+    (train, holdout, chars)
+}
