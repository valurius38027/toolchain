ning_sequences.len(),
+        holdout_sequences.len()
     );
-    println!("ema_feedback,{seed},{epochs},{parameters},{loss:.6}");
+    println!("condition,seed,epochs,parameters,holdout_nll,elapsed_seconds");
+    for seed in seed_start..seed_start + seed_count as u64 {
+        let (parameters, loss, seconds) = train_sparse(
+            vocabulary.vocab_size(),
+            &training_sequences,
+            &holdout_sequences,
+            epochs,
+            seed,
+            false,
+        );
+        println!("context_free,{seed},{epochs},{parameters},{loss:.6},{seconds:.6}");
 
-    let (parameters, loss) = train_rnn(
-        vocabulary.vocab_size(),
-        &training_sequences,
-        &holdout_sequences,
-        epochs,
-        seed,
-    );
-    println!("vanilla_rnn,{seed},{epochs},{parameters},{loss:.6}");
+        let (parameters, loss, seconds) = train_sparse(
+            vocabulary.vocab_size(),
+            &training_sequences,
+            &holdout_sequences,
+            epochs,
+            seed,
+            true,
+        );
+        println!("ema_feedback,{seed},{epochs},{parameters},{loss:.6},{seconds:.6}");
+
+        let (parameters, loss, seconds) = train_rnn(
+            vocabulary.vocab_size(),
+            &training_sequences,
+            &holdout_sequences,
+            epochs,
+            seed,
+        );
+        println!("vanilla_rnn,{seed},{epochs},{parameters},{loss:.6},{seconds:.6}");
+    }
 }
