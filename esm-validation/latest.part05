+
+#[test]
+fn normalized_error_reports_fraction_of_mixed_tolerance_budget() {
+    match compare_gradient(1.0, 1.01, 1.0e-7, 0.02, 0.01).unwrap() {
+        GradientComparison::Checked { normalized_error, .. } => {
+            assert!(normalized_error > 0.0 && normalized_error <= 1.0);
+        }
+        GradientComparison::BelowFloor => panic!("material gradients must be checked"),
+    }
+}
