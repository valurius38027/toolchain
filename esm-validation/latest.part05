+
+#[test]
+fn independent_subspace_language_model_preserves_global_state_width() {
+    let model = LmModel::new(
+        LmHyperParams {
+            vocab_size: 8,
+            d_model: 6,
+            block_hidden: 5,
+            num_blocks: 4,
+            top_k: 2,
+            num_layers: 2,
+            g_dim: 4,
+            lambda: 0.8,
+            independent_subspace: true,
+            use_feedback: true,
+            gated_feedback: false,
+            use_retrieval: false,
+            retrieval_window: 0,
+            d_key: 3,
+        },
+        23,
+    );
+    let tokens = [1usize, 4, 2, 5, 1, 4];
+    let out = model.forward_sequence(&tokens);
+    assert_eq!(out.per_step_logits.len(), tokens.len());
+    assert_eq!(out.per_step_layer_indices.len(), tokens.len());
+}
